# ========================================
# Smart Library - Environment Configuration
# Copy this file to .env and fill in your values
# ========================================

NODE_ENV=development
PORT=3000
APP_NAME=Smart Library

# ======================
# API Keys & Services
# ======================

# OpenAI
# OPENAI_API_KEY=sk-proj-...

# Anthropic / Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Groq
# GROQ_API_KEY=gsk_...

# Vector Database (if using Pinecone, Weaviate, etc.)
# PINECONE_API_KEY=...
# PINECONE_INDEX_NAME=...

# Supabase (optional)
# SUPABASE_URL=https://...
# SUPABASE_ANON_KEY=...

# ======================
# Application Settings
# ======================

LOG_LEVEL=info
MAX_RETRIEVAL_RESULTS=10
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# CORS (for frontend)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

